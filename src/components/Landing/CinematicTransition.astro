<!-- 
  CinematicTransition.astro
  Global overlay for cinematic page transitions.
  Usage: place <CinematicTransition /> anywhere in <body>.
-->

<div id="cinematic-overlay" aria-hidden="true">
  <!-- Phase 1: Clouds -->
  <div class="clouds-layer">
    <div class="cloud cloud-1"></div>
    <div class="cloud cloud-2"></div>
    <div class="cloud cloud-3"></div>
    <div class="cloud cloud-4"></div>
    <div class="cloud cloud-5"></div>
    <div class="cloud cloud-6"></div>
    <div class="cloud cloud-7"></div>
    <div class="cloud cloud-8"></div>
  </div>

  <!-- Phase 2: Flight effect -->
  <div class="flight-layer"></div>

  <!-- Phase 3: Map reveal -->
  <div class="map-layer">
    <div class="map-content">
      <div class="map-grid"></div>
      <div class="compass-rose"></div>
      <div class="map-text map-text-1">TERRA INCOGNITA</div>
      <div class="map-text map-text-2">MARE NOSTRUM</div>
      <div class="map-text map-text-3">✦</div>
    </div>
  </div>
</div>

<style>
  /* BASE OVERLAY */
  #cinematic-overlay {
    position: fixed;
    inset: 0;
    z-index: 9999;
    pointer-events: none;
    opacity: 0;
    overflow: hidden;
  }

  #cinematic-overlay.active {
    pointer-events: all;
    opacity: 1;
  }

  /*     PHASE 1 — CLOUDS DESCEND  */
  .clouds-layer {
    position: absolute;
    inset: 0;
    z-index: 3;
  }

  .cloud {
    position: absolute;
    border-radius: 50%;
    background: radial-gradient(ellipse at center,
      rgba(255, 255, 255, 0.95) 0%,
      rgba(240, 240, 245, 0.85) 30%,
      rgba(220, 225, 235, 0.6) 60%,
      transparent 100%);
    transform: translateY(-120%);
    opacity: 0;
    will-change: transform, opacity;
  }

  /* Cloud sizes and positions */
  .cloud-1 { width: 110vw; height: 45vh; top: -5%;  left: -10%; }
  .cloud-2 { width: 90vw;  height: 40vh; top: 10%;  left: 5%;   }
  .cloud-3 { width: 120vw; height: 50vh; top: 20%;  left: -15%; }
  .cloud-4 { width: 100vw; height: 42vh; top: 35%;  left: -5%;  }
  .cloud-5 { width: 115vw; height: 48vh; top: 45%;  left: -8%;  }
  .cloud-6 { width: 105vw; height: 44vh; top: 55%;  left: 0%;   }
  .cloud-7 { width: 125vw; height: 52vh; top: 65%;  left: -12%; }
  .cloud-8 { width: 110vw; height: 46vh; top: 75%;  left: -5%;  }

  /* Animate when active */
  #cinematic-overlay.active .cloud {
    animation: clouds-descend 700ms cubic-bezier(0.25, 0.46, 0.45, 0.94) forwards;
  }

  #cinematic-overlay.active .cloud-1 { animation-delay: 0ms;   }
  #cinematic-overlay.active .cloud-2 { animation-delay: 50ms;  }
  #cinematic-overlay.active .cloud-3 { animation-delay: 80ms;  }
  #cinematic-overlay.active .cloud-4 { animation-delay: 120ms; }
  #cinematic-overlay.active .cloud-5 { animation-delay: 160ms; }
  #cinematic-overlay.active .cloud-6 { animation-delay: 200ms; }
  #cinematic-overlay.active .cloud-7 { animation-delay: 240ms; }
  #cinematic-overlay.active .cloud-8 { animation-delay: 280ms; }

  @keyframes clouds-descend {
    0% {
      transform: translateY(-120%);
      opacity: 0;
    }
    30% {
      opacity: 0.9;
    }
    100% {
      transform: translateY(0);
      opacity: 1;
    }
  }

  /* PHASE 2 — FLIGHT ZOOM */
  .flight-layer {
    position: absolute;
    inset: 0;
    z-index: 4;
    background: radial-gradient(
      ellipse at 50% 50%,
      transparent 0%,
      rgba(255, 255, 255, 0.15) 40%,
      rgba(200, 210, 230, 0.5) 70%,
      rgba(160, 175, 210, 0.8) 100%
    );
    opacity: 0;
    transform: scale(1);
    will-change: transform, opacity;
  }

  #cinematic-overlay.active .flight-layer {
    animation: flight-zoom 800ms 450ms cubic-bezier(0.22, 1, 0.36, 1) forwards;
  }

  @keyframes flight-zoom {
    0% {
      opacity: 0;
      transform: scale(1);
    }
    30% {
      opacity: 0.7;
    }
    100% {
      opacity: 0;
      transform: scale(3);
    }
  }

  /* PHASE 3 — MAP REVEAL */
  .map-layer {
    position: absolute;
    inset: 0;
    z-index: 5;
    opacity: 0;
    clip-path: circle(0% at 50% 50%);
    will-change: clip-path, opacity;
    background:
      /* Aged parchment base */
      radial-gradient(ellipse at 30% 40%, #e8d5a3 0%, transparent 50%),
      radial-gradient(ellipse at 70% 60%, #d4bc82 0%, transparent 50%),
      radial-gradient(ellipse at 50% 50%, #dcc998 0%, #c4a86a 60%, #a0845a 100%);
  }

  #cinematic-overlay.active .map-layer {
    animation: map-reveal 700ms 900ms cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }

  @keyframes map-reveal {
    0% {
      clip-path: circle(0% at 50% 50%);
      opacity: 0;
    }
    20% {
      opacity: 1;
    }
    100% {
      clip-path: circle(80% at 50% 50%);
      opacity: 1;
    }
  }

  /* Map content styling */
  .map-content {
    position: absolute;
    inset: 0;
    overflow: hidden;
  }

  /* Grid lines simulating map coordinates */
  .map-grid {
    position: absolute;
    inset: 0;
    background-image:
      /* Longitude lines */
      repeating-linear-gradient(
        90deg,
        transparent,
        transparent calc(10vw - 1px),
        rgba(139, 109, 63, 0.2) 10vw
      ),
      /* Latitude lines */
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent calc(10vh - 1px),
        rgba(139, 109, 63, 0.2) 10vh
      );
    opacity: 0;
    animation: none;
  }

  #cinematic-overlay.active .map-grid {
    animation: fade-in 500ms 1100ms ease forwards;
  }

  /* Compass rose */
  .compass-rose {
    position: absolute;
    width: 120px;
    height: 120px;
    bottom: 15%;
    right: 12%;
    border: 2px solid rgba(139, 109, 63, 0.4);
    border-radius: 50%;
    opacity: 0;
  }

  .compass-rose::before {
    content: "N";
    position: absolute;
    top: 5px;
    left: 50%;
    transform: translateX(-50%);
    font-family: "Georgia", serif;
    font-size: 16px;
    color: rgba(120, 90, 50, 0.7);
  }

  .compass-rose::after {
    content: "";
    position: absolute;
    top: 50%;
    left: 50%;
    width: 2px;
    height: 50%;
    background: rgba(139, 109, 63, 0.5);
    transform: translate(-50%, -100%);
    transform-origin: bottom center;
  }

  #cinematic-overlay.active .compass-rose {
    animation: fade-in 400ms 1200ms ease forwards;
  }

  /* Decorative text */
  .map-text {
    position: absolute;
    font-family: "Georgia", "Times New Roman", serif;
    color: rgba(120, 90, 50, 0.5);
    letter-spacing: 6px;
    text-transform: uppercase;
    font-style: italic;
    opacity: 0;
    white-space: nowrap;
  }

  .map-text-1 {
    top: 30%;
    left: 15%;
    font-size: clamp(14px, 2.5vw, 28px);
    transform: rotate(-5deg);
  }

  .map-text-2 {
    top: 60%;
    left: 40%;
    font-size: clamp(12px, 2vw, 22px);
    transform: rotate(3deg);
  }

  .map-text-3 {
    top: 45%;
    left: 55%;
    font-size: clamp(20px, 3vw, 40px);
    letter-spacing: 0;
  }

  #cinematic-overlay.active .map-text {
    animation: fade-in 400ms 1150ms ease forwards;
  }

  /* Vignette effect on the map */
  .map-layer::after {
    content: "";
    position: absolute;
    inset: 0;
    background: radial-gradient(
      ellipse at 50% 50%,
      transparent 30%,
      rgba(80, 60, 30, 0.3) 100%
    );
    pointer-events: none;
  }

  /* Shared keyframe */
  @keyframes fade-in {
    from { opacity: 0; }
    to   { opacity: 1; }
  }

  /* BODY BLUR EFFECT (applied to page content) */
  :global(body.transitioning > *:not(#cinematic-overlay)) {
    transition: filter 600ms ease, transform 600ms ease;
    filter: blur(6px);
    transform: scale(1.05);
  }
</style>

<script>
  function startCinematicTransition(targetUrl: string) {
    const overlay = document.getElementById('cinematic-overlay');
    if (!overlay || overlay.classList.contains('active')) return;

    // Apply blur to page content
    document.body.classList.add('transitioning');

    // Activate the overlay animations
    overlay.classList.add('active');

    // Navigate after animation completes
    const TRANSITION_DURATION = 1800;
    setTimeout(() => {
      window.location.href = targetUrl;
    }, TRANSITION_DURATION);
  }

  // Expose globally
  (window as any).startCinematicTransition = startCinematicTransition;

  // Reset overlay when user navigates back (bfcache restore)
  function resetTransition() {
    const overlay = document.getElementById('cinematic-overlay');
    if (overlay) {
      overlay.classList.remove('active');
    }
    document.body.classList.remove('transitioning');
  }

  // pageshow fires when page is restored from bfcache (back/forward)
  window.addEventListener('pageshow', (event) => {
    if (event.persisted) {
      resetTransition();
    }
  });

  // Also reset on regular page load (covers hard navigations)
  resetTransition();

  // Auto-bind any links with data-transition-target
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll<HTMLAnchorElement>('[data-transition-target]').forEach((link) => {
      link.addEventListener('click', (e) => {
        e.preventDefault();
        const target = link.getAttribute('data-transition-target') || link.href;
        startCinematicTransition(target);
      });
    });
  });
</script>