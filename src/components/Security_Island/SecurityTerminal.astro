---
---

<section id="logs" class="si-section si-terminal-section">
  <div class="si-container">
    <div class="si-section-header si-reveal">
      <span class="si-section-num">06 / 10</span>
      <h2 class="si-section-title">Security Terminal</h2>
      <p class="si-section-desc">Interactive infrastructure analysis interface. Type <code class="si-code">help</code> to begin.</p>
    </div>

    <div class="si-terminal-wrapper si-reveal">
      <!-- Terminal chrome -->
      <div class="si-terminal-chrome">
        <div class="si-chrome-dots">
          <span class="si-dot-red"></span>
          <span class="si-dot-yellow"></span>
          <span class="si-dot-green"></span>
        </div>
        <div class="si-chrome-title">sec@observatory:~</div>
        <div class="si-chrome-badge">SECURE SHELL</div>
      </div>

      <!-- Terminal body -->
      <div class="si-terminal-body" id="si-terminal-body">
        <div class="si-t-welcome">
          <div class="si-t-line">Security Observatory — Interactive Shell v1.0</div>
          <div class="si-t-line si-t-muted">Type <span class="si-t-cyan">help</span> to list available commands.</div>
          <div class="si-t-line si-t-muted">All operations are observational — no system modifications.</div>
          <div class="si-t-spacer"></div>
        </div>
        <div id="si-t-history"></div>
        <!-- Input line -->
        <div class="si-t-input-row">
          <span class="si-t-prompt">sec@observatory:~$</span>
          <span class="si-t-prompt-sep">&nbsp;</span>
          <input
            type="text"
            id="si-t-input"
            class="si-t-input"
            autocomplete="off"
            autocorrect="off"
            autocapitalize="off"
            spellcheck="false"
            placeholder=""
          />
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .si-terminal-section {
    background: #070b14;
    border-top: 1px solid rgba(71, 193, 226, 0.06);
  }

  .si-code {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 13px;
    color: rgba(71, 193, 226, 0.75);
    background: rgba(71, 193, 226, 0.08);
    padding: 1px 5px;
    border-radius: 2px;
  }

  .si-terminal-wrapper {
    border-radius: 8px;
    overflow: hidden;
    border: 1px solid rgba(71, 193, 226, 0.12);
    box-shadow: 0 24px 64px rgba(0, 0, 0, 0.5);
  }

  .si-terminal-chrome {
    display: flex;
    align-items: center;
    gap: 12px;
    padding: 12px 16px;
    background: rgba(15, 20, 35, 0.95);
    border-bottom: 1px solid rgba(71, 193, 226, 0.08);
  }

  .si-chrome-dots {
    display: flex;
    gap: 6px;
  }

  .si-dot-red, .si-dot-yellow, .si-dot-green {
    width: 11px; height: 11px; border-radius: 50%;
  }

  .si-dot-red { background: rgba(255, 90, 90, 0.5); }
  .si-dot-yellow { background: rgba(255, 200, 60, 0.4); }
  .si-dot-green { background: rgba(100, 220, 120, 0.4); }

  .si-chrome-title {
    flex: 1;
    text-align: center;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 11px;
    color: rgba(180, 200, 220, 0.4);
    letter-spacing: 0.05em;
  }

  .si-chrome-badge {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 8px;
    letter-spacing: 0.15em;
    color: rgba(71, 193, 226, 0.4);
    border: 1px solid rgba(71, 193, 226, 0.15);
    padding: 2px 7px;
    border-radius: 2px;
    text-transform: uppercase;
  }

  .si-terminal-body {
    background: rgba(5, 8, 16, 0.98);
    padding: 20px;
    min-height: 380px;
    max-height: 480px;
    overflow-y: auto;
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    line-height: 1.7;
    cursor: text;
  }

  .si-t-line { color: rgba(180, 200, 220, 0.65); }
  .si-t-muted { color: rgba(180, 200, 220, 0.3); }
  .si-t-cyan { color: rgba(71, 193, 226, 0.8); }
  .si-t-green { color: rgba(100, 210, 140, 0.8); }
  .si-t-warn { color: rgba(230, 180, 80, 0.8); }
  .si-t-err { color: rgba(220, 90, 90, 0.8); }
  .si-t-spacer { height: 8px; }
  .si-t-prompt-line { color: rgba(71, 193, 226, 0.6); margin-bottom: 2px; }
  .si-t-output { color: rgba(180, 200, 220, 0.6); padding-left: 0; margin-bottom: 12px; }
  .si-t-output-line { line-height: 1.7; }

  .si-t-input-row {
    display: flex;
    align-items: center;
    margin-top: 4px;
  }

  .si-t-prompt {
    color: rgba(71, 193, 226, 0.65);
    flex-shrink: 0;
    user-select: none;
  }

  .si-t-input {
    flex: 1;
    background: none;
    border: none;
    outline: none;
    color: rgba(200, 220, 240, 0.85);
    font-family: 'IBM Plex Mono', monospace;
    font-size: 12px;
    caret-color: rgba(71, 193, 226, 0.8);
    padding: 0;
  }
</style>

<script>
  const COMMANDS: Record<string, string[]> = {
    help: [
      '  Available commands:',
      '',
      '  scan              — Run surface area scan',
      '  inspect headers   — Analyze HTTP security headers',
      '  show topology     — Display network topology summary',
      '  list findings     — Show all documented findings',
      '  analyze auth      — Review authentication configuration',
      '  check tls         — TLS/SSL configuration analysis',
      '  whoami            — Current session info',
      '  clear             — Clear terminal',
    ],
    scan: [
      '  [scan] Initiating surface area analysis...',
      '',
      '  → Resolving hostname............ done',
      '  → Probing open ports............ 443, 80 (public)',
      '  → Internal ports................ 8080, 6379, 5432',
      '  → WAF detection................. Cloudflare (confidence: high)',
      '  → TLS version................... TLSv1.3',
      '  → HSTS.......................... enabled (max-age=31536000)',
      '',
      '  Surface score: 3.2 / 10 — LOW exposure',
      '  2 medium findings · 3 low findings · 0 critical',
    ],
    'inspect headers': [
      '  [headers] Analyzing HTTP security headers...',
      '',
      '  ✓  Strict-Transport-Security: max-age=31536000',
      '  ✓  X-Content-Type-Options: nosniff',
      '  ✓  Permissions-Policy: present',
      '  ⚠  Content-Security-Policy: MISSING',
      '  ⚠  X-Frame-Options: MISSING',
      '  ℹ  Referrer-Policy: no-referrer-when-downgrade',
      '',
      '  Recommendation: Add CSP and X-Frame-Options headers.',
      '  Impact: Medium — reduces XSS and clickjacking exposure.',
    ],
    'show topology': [
      '  [topology] Network topology summary',
      '',
      '  Internet → CDN → WAF → Gateway',
      '                            ↓',
      '                    ┌──── API ────┐',
      '                    ↓             ↓',
      '                  Cache         Auth',
      '                    ↓             ↓',
      '                 Database ←──────┘',
      '                    ↑',
      '               (no direct external access)',
      '',
      '  External services: payment-api, email-srv (egress only)',
      '  Nodes: 6 internal · 3 perimeter · 2 external deps',
    ],
    'list findings': [
      '  [findings] Documented security observations',
      '',
      '  #001  Missing CSP headers              Severity: MEDIUM',
      '        X-Frame-Options also absent. Recommend proxy-level fix.',
      '',
      '  #002  Rate limiting absent on API routes  Severity: MEDIUM',
      '        /api/v1/users and /comments have no per-route limits.',
      '',
      '  #003  Server version exposed           Severity: LOW',
      '        nginx/1.24.0 in Server header. Recommend: server_tokens off',
      '',
      '  #004  HSTS not preloaded               Severity: LOW',
      '        Submit to browser preload list for stronger enforcement.',
      '',
      '  #005  Refresh token not rotated        Severity: LOW',
      '        Rotate refresh tokens on use to limit session fixation risk.',
    ],
    'analyze auth': [
      '  [auth] Authentication configuration review',
      '',
      '  Algorithm:       RS256 (asymmetric — good)',
      '  Token lifetime:  access=1h · refresh=7d',
      '  Signing key:     RSA-4096 (strong)',
      '  RBAC:            permission matrix enforced (good)',
      '',
      '  Observations:',
      '  ⚠  Refresh tokens not rotated on use (fixation risk)',
      '  ℹ  No device fingerprinting on session creation',
      '  ✓  CSRF: double-submit cookie pattern (adequate)',
      '  ✓  Passwords: bcrypt cost factor 12 (acceptable)',
      '',
      '  Overall posture: ADEQUATE — 1 improvement recommended.',
    ],
    'check tls': [
      '  [tls] SSL/TLS configuration analysis',
      '',
      '  TLSv1.3:  ✓ supported (preferred)',
      '  TLSv1.2:  ✓ fallback only',
      '  TLSv1.1:  ✗ disabled',
      '  TLSv1.0:  ✗ disabled',
      '',
      '  Certificate:   RSA-4096, SHA-256',
      '  Validity:      87 days remaining',
      '  Auto-renew:    configured (certbot)',
      '  OCSP stapling: enabled',
      '  HSTS:          max-age=31536000; includeSubDomains',
      '',
      '  Grade: A — strong configuration.',
    ],
    whoami: [
      '  Session: sec@observatory',
      '  Role:    ANALYST — read-only access',
      '  Context: Security Island · Portfolio',
      '  Purpose: Infrastructure observation · learning',
    ],
  };

  const body = document.getElementById('si-terminal-body')!;
  const input = document.getElementById('si-t-input') as HTMLInputElement;
  const history = document.getElementById('si-t-history')!;
  const inputRow = input.closest('.si-t-input-row')!;
  let cmdHistory: string[] = [];
  let histIdx = -1;

  body.addEventListener('click', () => input.focus());
  input.focus();

  const append = (text: string, cls: string = 'si-t-line') => {
    const div = document.createElement('div');
    div.className = cls;
    div.innerHTML = text;
    history.appendChild(div);
  };

  input.addEventListener('keydown', (e) => {
    if (e.key === 'ArrowUp') {
      e.preventDefault();
      if (histIdx < cmdHistory.length - 1) histIdx++;
      input.value = cmdHistory[cmdHistory.length - 1 - histIdx] || '';
    }
    if (e.key === 'ArrowDown') {
      e.preventDefault();
      if (histIdx > 0) histIdx--;
      input.value = cmdHistory[cmdHistory.length - 1 - histIdx] || '';
    }
    if (e.key !== 'Enter') return;

    const cmd = input.value.trim().toLowerCase();
    input.value = '';
    histIdx = -1;

    // Echo command
    const promptLine = document.createElement('div');
    promptLine.className = 'si-t-prompt-line';
    promptLine.innerHTML = `<span style="color:rgba(71,193,226,0.6)">sec@observatory:~$</span> ${cmd}`;
    history.appendChild(promptLine);

    if (!cmd) { body.scrollTop = body.scrollHeight; return; }
    cmdHistory.push(cmd);

    if (cmd === 'clear') {
      history.innerHTML = '';
      body.scrollTop = body.scrollHeight;
      return;
    }

    const output = document.createElement('div');
    output.className = 'si-t-output';

    const lines = COMMANDS[cmd];
    if (lines) {
      lines.forEach(line => {
        const lEl = document.createElement('div');
        lEl.className = 'si-t-output-line';
        if (line.includes('✓') || line.includes('done')) lEl.style.color = 'rgba(100,210,140,0.75)';
        else if (line.includes('⚠') || line.includes('MISSING') || line.includes('MEDIUM')) lEl.style.color = 'rgba(230,180,80,0.75)';
        else if (line.includes('✗') || line.includes('ERROR')) lEl.style.color = 'rgba(220,90,90,0.7)';
        else if (line.includes('ℹ') || line.startsWith('  #')) lEl.style.color = 'rgba(71,193,226,0.65)';
        else lEl.style.color = 'rgba(180,200,220,0.55)';
        lEl.textContent = line;
        output.appendChild(lEl);
      });
    } else {
      const errLine = document.createElement('div');
      errLine.className = 'si-t-err si-t-output-line';
      errLine.textContent = `  Command not found: '${cmd}'. Type 'help' for available commands.`;
      output.appendChild(errLine);
    }

    history.appendChild(output);

    // Move input row to bottom
    body.appendChild(inputRow);
    body.scrollTop = body.scrollHeight;
    input.focus();
  });
</script>
