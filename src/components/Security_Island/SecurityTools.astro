---
---

<section id="tools" class="si-section si-tools-section">
  <div class="si-container">
    <div class="si-section-header si-reveal">
      <span class="si-section-num">07 / 10</span>
      <h2 class="si-section-title">Tools</h2>
      <p class="si-section-desc">Analytical instruments for infrastructure inspection and security research.</p>
    </div>

    <div class="si-tools-grid si-reveal">

      <div class="si-tool-card">
        <div class="si-tool-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
            <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
            <path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <div class="si-tool-body">
          <span class="si-tool-name">DNS Lookup</span>
          <span class="si-tool-desc">Resolve hostnames, inspect records, trace delegation chains and TTL analysis.</span>
        </div>
        <div class="si-tool-tags">
          <span class="si-tool-tag">A/AAAA</span>
          <span class="si-tool-tag">CNAME</span>
          <span class="si-tool-tag">MX</span>
          <span class="si-tool-tag">TXT</span>
        </div>
        <div class="si-tool-status si-ts-ok">OPERATIONAL</div>
      </div>

      <div class="si-tool-card">
        <div class="si-tool-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
            <rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="1.5"/>
            <path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            <circle cx="12" cy="16" r="1.5" fill="currentColor"/>
          </svg>
        </div>
        <div class="si-tool-body">
          <span class="si-tool-name">JWT Decoder</span>
          <span class="si-tool-desc">Decode and inspect JWT tokens. Verify structure, claims, expiry and algorithm.</span>
        </div>
        <div class="si-tool-tags">
          <span class="si-tool-tag">HS256</span>
          <span class="si-tool-tag">RS256</span>
          <span class="si-tool-tag">ES256</span>
        </div>
        <div class="si-tool-status si-ts-ok">OPERATIONAL</div>
      </div>

      <div class="si-tool-card">
        <div class="si-tool-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <div class="si-tool-body">
          <span class="si-tool-name">SSL Inspector</span>
          <span class="si-tool-desc">Analyze TLS configuration, certificate chain, expiry and cipher suites.</span>
        </div>
        <div class="si-tool-tags">
          <span class="si-tool-tag">TLS 1.3</span>
          <span class="si-tool-tag">Cert chain</span>
          <span class="si-tool-tag">OCSP</span>
        </div>
        <div class="si-tool-status si-ts-ok">OPERATIONAL</div>
      </div>

      <div class="si-tool-card">
        <div class="si-tool-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
            <path d="M4 6h16M4 10h16M4 14h10M4 18h8" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
          </svg>
        </div>
        <div class="si-tool-body">
          <span class="si-tool-name">Header Analyzer</span>
          <span class="si-tool-desc">Parse HTTP response headers. Score security posture against OWASP recommendations.</span>
        </div>
        <div class="si-tool-tags">
          <span class="si-tool-tag">CSP</span>
          <span class="si-tool-tag">HSTS</span>
          <span class="si-tool-tag">CORS</span>
        </div>
        <div class="si-tool-status si-ts-ok">OPERATIONAL</div>
      </div>

      <div class="si-tool-card">
        <div class="si-tool-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
            <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z" stroke="currentColor" stroke-width="1.5"/>
            <path d="M3.27 6.96L12 12.01l8.73-5.05M12 22.08V12" stroke="currentColor" stroke-width="1.5"/>
          </svg>
        </div>
        <div class="si-tool-body">
          <span class="si-tool-name">Request Analyzer</span>
          <span class="si-tool-desc">Inspect HTTP request/response cycles. Identify anomalies, leaked headers and info disclosure.</span>
        </div>
        <div class="si-tool-tags">
          <span class="si-tool-tag">HTTP/2</span>
          <span class="si-tool-tag">gRPC</span>
          <span class="si-tool-tag">WebSocket</span>
        </div>
        <div class="si-tool-status si-ts-ok">OPERATIONAL</div>
      </div>

      <div class="si-tool-card si-tool-wip">
        <div class="si-tool-icon">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none">
            <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="si-tool-body">
          <span class="si-tool-name">Traffic Analyzer</span>
          <span class="si-tool-desc">Pattern analysis on request volume. Rate limit detection and anomaly baseline comparison.</span>
        </div>
        <div class="si-tool-tags">
          <span class="si-tool-tag">Baseline</span>
          <span class="si-tool-tag">Anomaly</span>
        </div>
        <div class="si-tool-status si-ts-dev">IN DEVELOPMENT</div>
      </div>

    </div>
  </div>
</section>

<style>
  .si-tools-section {
    background: linear-gradient(180deg, #0a0f1e 0%, #070b14 100%);
    border-top: 1px solid rgba(71, 193, 226, 0.06);
  }

  .si-tools-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 16px;
  }

  @media (max-width: 900px) { .si-tools-grid { grid-template-columns: repeat(2, 1fr); } }
  @media (max-width: 560px) { .si-tools-grid { grid-template-columns: 1fr; } }

  .si-tool-card {
    background: rgba(10, 15, 30, 0.8);
    border: 1px solid rgba(71, 193, 226, 0.1);
    border-radius: 6px;
    padding: 22px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    transition: border-color 0.25s, transform 0.25s, background 0.25s;
    cursor: default;
  }

  .si-tool-card:hover {
    border-color: rgba(71, 193, 226, 0.22);
    background: rgba(71, 193, 226, 0.04);
    transform: translateY(-2px);
  }

  .si-tool-wip {
    opacity: 0.55;
    border-style: dashed;
  }

  .si-tool-icon {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(71, 193, 226, 0.55);
    background: rgba(71, 193, 226, 0.06);
    border: 1px solid rgba(71, 193, 226, 0.1);
    border-radius: 5px;
  }

  .si-tool-body {
    display: flex;
    flex-direction: column;
    gap: 5px;
    flex: 1;
  }

  .si-tool-name {
    font-family: 'Syne', sans-serif;
    font-size: 14px;
    font-weight: 600;
    color: rgba(200, 220, 240, 0.85);
    letter-spacing: 0.02em;
  }

  .si-tool-desc {
    font-family: 'DM Sans', sans-serif;
    font-size: 12px;
    font-weight: 300;
    line-height: 1.6;
    color: rgba(180, 200, 220, 0.45);
  }

  .si-tool-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  .si-tool-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.1em;
    color: rgba(71, 193, 226, 0.55);
    background: rgba(71, 193, 226, 0.06);
    border: 1px solid rgba(71, 193, 226, 0.12);
    padding: 2px 7px;
    border-radius: 2px;
    text-transform: uppercase;
  }

  .si-tool-status {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    padding: 4px 10px;
    border-radius: 2px;
    align-self: flex-start;
    border: 1px solid;
  }

  .si-ts-ok {
    color: rgba(100, 210, 140, 0.7);
    border-color: rgba(100, 210, 140, 0.2);
    background: rgba(100, 210, 140, 0.04);
  }

  .si-ts-dev {
    color: rgba(180, 200, 220, 0.4);
    border-color: rgba(180, 200, 220, 0.12);
    background: transparent;
  }
</style>
