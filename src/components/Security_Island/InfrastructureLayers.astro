---
---

<section id="infrastructure" class="si-section si-infra-section">
  <div class="si-container">
    <div class="si-section-header si-reveal">
      <span class="si-section-num">02 / 10</span>
      <h2 class="si-section-title">Infrastructure Layers</h2>
      <p class="si-section-desc">Layered defensive architecture — each boundary a deliberate security decision.</p>
    </div>

    <div class="si-infra-layout si-reveal">
      <!-- Left: Layer stack -->
      <div class="si-layer-stack">
        <div class="si-layer" data-layer="0">
          <div class="si-layer-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.5"/>
              <path d="M2 12h20M12 2a15 15 0 0 1 0 20M12 2a15 15 0 0 0 0 20" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <div class="si-layer-body">
            <span class="si-layer-name">Internet</span>
            <span class="si-layer-desc">External traffic origin · untrusted perimeter</span>
          </div>
          <div class="si-layer-tag si-tag-neutral">PUBLIC</div>
        </div>

        <div class="si-layer-connector">
          <div class="si-packet" style="--pdel:0s;"></div>
          <div class="si-packet" style="--pdel:0.6s;"></div>
          <div class="si-packet" style="--pdel:1.2s;"></div>
        </div>

        <div class="si-layer" data-layer="1">
          <div class="si-layer-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <rect x="2" y="6" width="20" height="12" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M2 10h20" stroke="currentColor" stroke-width="1.5"/>
              <circle cx="6" cy="8" r="1" fill="currentColor"/>
              <circle cx="9" cy="8" r="1" fill="currentColor"/>
            </svg>
          </div>
          <div class="si-layer-body">
            <span class="si-layer-name">Gateway</span>
            <span class="si-layer-desc">Entry point · SSL termination · DDoS mitigation</span>
          </div>
          <div class="si-layer-tag si-tag-info">EDGE</div>
        </div>

        <div class="si-layer-connector">
          <div class="si-packet" style="--pdel:0.2s;"></div>
          <div class="si-packet" style="--pdel:0.8s;"></div>
          <div class="si-packet" style="--pdel:1.4s;"></div>
        </div>

        <div class="si-layer" data-layer="2">
          <div class="si-layer-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M12 2L4 6V12C4 16.4 7.4 20.5 12 22C16.6 20.5 20 16.4 20 12V6L12 2Z" stroke="currentColor" stroke-width="1.5"/>
              <path d="M9 12l2 2 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="si-layer-body">
            <span class="si-layer-name">WAF</span>
            <span class="si-layer-desc">Web Application Firewall · OWASP ruleset · rate limit</span>
          </div>
          <div class="si-layer-tag si-tag-ok">ACTIVE</div>
        </div>

        <div class="si-layer-connector">
          <div class="si-packet" style="--pdel:0.4s;"></div>
          <div class="si-packet" style="--pdel:1.0s;"></div>
          <div class="si-packet" style="--pdel:1.6s;"></div>
        </div>

        <div class="si-layer" data-layer="3">
          <div class="si-layer-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <path d="M8 6h13M8 12h13M8 18h13M3 6h.01M3 12h.01M3 18h.01" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="si-layer-body">
            <span class="si-layer-name">Reverse Proxy</span>
            <span class="si-layer-desc">Load balancing · header stripping · path routing</span>
          </div>
          <div class="si-layer-tag si-tag-info">NGINX</div>
        </div>

        <div class="si-layer-connector">
          <div class="si-packet" style="--pdel:0.1s;"></div>
          <div class="si-packet" style="--pdel:0.7s;"></div>
          <div class="si-packet" style="--pdel:1.3s;"></div>
        </div>

        <div class="si-layer" data-layer="4">
          <div class="si-layer-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <rect x="3" y="11" width="18" height="11" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
              <circle cx="12" cy="16" r="1.5" fill="currentColor"/>
            </svg>
          </div>
          <div class="si-layer-body">
            <span class="si-layer-name">Auth Layer</span>
            <span class="si-layer-desc">JWT validation · session management · RBAC enforcement</span>
          </div>
          <div class="si-layer-tag si-tag-ok">SECURED</div>
        </div>

        <div class="si-layer-connector">
          <div class="si-packet" style="--pdel:0.3s;"></div>
          <div class="si-packet" style="--pdel:0.9s;"></div>
          <div class="si-packet" style="--pdel:1.5s;"></div>
        </div>

        <div class="si-layer" data-layer="5">
          <div class="si-layer-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <rect x="2" y="3" width="20" height="14" rx="2" stroke="currentColor" stroke-width="1.5"/>
              <path d="M8 21h8M12 17v4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="si-layer-body">
            <span class="si-layer-name">Services</span>
            <span class="si-layer-desc">Isolated containers · internal network · service mesh</span>
          </div>
          <div class="si-layer-tag si-tag-info">DOCKER</div>
        </div>

        <div class="si-layer-connector">
          <div class="si-packet" style="--pdel:0.5s;"></div>
          <div class="si-packet" style="--pdel:1.1s;"></div>
          <div class="si-packet" style="--pdel:1.7s;"></div>
        </div>

        <div class="si-layer" data-layer="6">
          <div class="si-layer-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none">
              <ellipse cx="12" cy="5" rx="9" ry="3" stroke="currentColor" stroke-width="1.5"/>
              <path d="M3 5v14c0 1.66 4.03 3 9 3s9-1.34 9-3V5" stroke="currentColor" stroke-width="1.5"/>
              <path d="M3 12c0 1.66 4.03 3 9 3s9-1.34 9-3" stroke="currentColor" stroke-width="1.5"/>
            </svg>
          </div>
          <div class="si-layer-body">
            <span class="si-layer-name">Database</span>
            <span class="si-layer-desc">Encrypted at rest · access logs · no public exposure</span>
          </div>
          <div class="si-layer-tag si-tag-secure">PRIVATE</div>
        </div>
      </div>

      <!-- Right: annotations -->
      <div class="si-infra-annotations">
        <div class="si-annotation si-reveal">
          <div class="si-annotation-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
              <path d="M12 2L4 6V12C4 16.4 7.4 20.5 12 22C16.6 20.5 20 16.4 20 12V6L12 2Z" stroke="rgba(71,193,226,0.6)" stroke-width="1.5"/>
            </svg>
          </div>
          <div class="si-annotation-body">
            <span class="si-annotation-title">Defense in Depth</span>
            <p class="si-annotation-text">Each layer provides independent protection. A failure at one boundary does not compromise the entire system.</p>
          </div>
        </div>

        <div class="si-annotation si-reveal">
          <div class="si-annotation-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
              <circle cx="12" cy="12" r="10" stroke="rgba(100,210,140,0.6)" stroke-width="1.5"/>
              <path d="M9 12l2 2 4-4" stroke="rgba(100,210,140,0.6)" stroke-width="1.5" stroke-linecap="round"/>
            </svg>
          </div>
          <div class="si-annotation-body">
            <span class="si-annotation-title">Zero Trust Principle</span>
            <p class="si-annotation-text">Every request is verified. Internal services do not assume trust simply because a request reached the internal network.</p>
          </div>
        </div>

        <div class="si-annotation si-reveal">
          <div class="si-annotation-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none">
              <path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7z" stroke="rgba(230,180,80,0.6)" stroke-width="1.5"/>
              <circle cx="12" cy="12" r="3" stroke="rgba(230,180,80,0.6)" stroke-width="1.5"/>
            </svg>
          </div>
          <div class="si-annotation-body">
            <span class="si-annotation-title">Observability</span>
            <p class="si-annotation-text">Full request tracing from edge to database. Anomalies surface through correlated log analysis, not guesswork.</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .si-infra-section {
    background: #0a0f1e;
    border-top: 1px solid rgba(71, 193, 226, 0.06);
  }

  .si-infra-layout {
    display: grid;
    grid-template-columns: 1fr 380px;
    gap: 64px;
    align-items: start;
  }

  @media (max-width: 900px) {
    .si-infra-layout { grid-template-columns: 1fr; gap: 40px; }
  }

  /* Layer stack */
  .si-layer-stack {
    display: flex;
    flex-direction: column;
  }

  .si-layer {
    display: flex;
    align-items: center;
    gap: 16px;
    padding: 16px 20px;
    background: rgba(10, 15, 30, 0.6);
    border: 1px solid rgba(71, 193, 226, 0.1);
    border-radius: 4px;
    cursor: default;
    transition: background 0.2s, border-color 0.2s, transform 0.2s;
  }

  .si-layer:hover {
    background: rgba(71, 193, 226, 0.06);
    border-color: rgba(71, 193, 226, 0.22);
    transform: translateX(4px);
  }

  .si-layer-icon {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    color: rgba(71, 193, 226, 0.5);
    flex-shrink: 0;
    background: rgba(71, 193, 226, 0.06);
    border-radius: 4px;
    border: 1px solid rgba(71, 193, 226, 0.1);
  }

  .si-layer-body {
    flex: 1;
    display: flex;
    flex-direction: column;
    gap: 3px;
  }

  .si-layer-name {
    font-family: 'Syne', 'IBM Plex Mono', monospace;
    font-size: 13px;
    font-weight: 600;
    color: rgba(200, 220, 240, 0.85);
    letter-spacing: 0.02em;
  }

  .si-layer-desc {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 10px;
    color: rgba(180, 200, 220, 0.35);
    letter-spacing: 0.05em;
  }

  .si-layer-tag {
    font-family: 'IBM Plex Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    padding: 3px 8px;
    border-radius: 2px;
    border: 1px solid;
    flex-shrink: 0;
    text-transform: uppercase;
  }

  .si-tag-neutral { color: rgba(180, 200, 220, 0.5); border-color: rgba(180, 200, 220, 0.2); background: rgba(180, 200, 220, 0.04); }
  .si-tag-info { color: rgba(71, 193, 226, 0.7); border-color: rgba(71, 193, 226, 0.2); background: rgba(71, 193, 226, 0.05); }
  .si-tag-ok { color: rgba(100, 210, 140, 0.7); border-color: rgba(100, 210, 140, 0.2); background: rgba(100, 210, 140, 0.04); }
  .si-tag-secure { color: rgba(140, 100, 220, 0.7); border-color: rgba(140, 100, 220, 0.2); background: rgba(140, 100, 220, 0.04); }

  /* Connectors */
  .si-layer-connector {
    width: 2px;
    height: 32px;
    background: linear-gradient(to bottom, rgba(71, 193, 226, 0.15), rgba(71, 193, 226, 0.08));
    margin: 0 auto 0 34px;
    position: relative;
    overflow: hidden;
  }

  .si-packet {
    position: absolute;
    width: 2px;
    height: 8px;
    background: rgba(71, 193, 226, 0.6);
    top: -8px;
    left: 0;
    animation: si-flow 1.8s linear var(--pdel) infinite;
    border-radius: 1px;
  }

  /* Annotations */
  .si-infra-annotations {
    display: flex;
    flex-direction: column;
    gap: 24px;
    padding-top: 8px;
  }

  .si-annotation {
    display: flex;
    gap: 14px;
    padding: 18px;
    background: rgba(10, 15, 30, 0.5);
    border: 1px solid rgba(71, 193, 226, 0.08);
    border-radius: 4px;
  }

  .si-annotation-icon {
    flex-shrink: 0;
    padding-top: 2px;
  }

  .si-annotation-title {
    display: block;
    font-family: 'Syne', sans-serif;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 0.08em;
    color: rgba(200, 220, 240, 0.75);
    text-transform: uppercase;
    margin-bottom: 6px;
  }

  .si-annotation-text {
    font-family: 'DM Sans', sans-serif;
    font-size: 13px;
    font-weight: 300;
    line-height: 1.65;
    color: rgba(180, 200, 220, 0.5);
  }

  @keyframes si-flow {
    0% { top: -8px; opacity: 0; }
    10% { opacity: 1; }
    90% { opacity: 1; }
    100% { top: 100%; opacity: 0; }
  }
</style>
