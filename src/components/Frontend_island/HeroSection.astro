

<section class="min-h-screen flex flex-col justify-center items-center relative overflow-hidden px-8">
  <div class="max-w-4xl mx-auto w-full relative z-10 flex flex-col items-center text-center">
    
    <div class="hero-content space-y-6">
      <h1 class="text-6xl md:text-8xl lg:text-9xl font-serif text-ink tracking-tight hero-title">
        Frontend Island
      </h1>
      
      <p class="text-xl md:text-3xl font-serif text-charcoal/80 italic hero-subtitle">
        I entered programming through the frontend.
      </p>

      <div class="pt-8 space-y-2 hero-text font-sans font-light text-warm-gray text-base md:text-lg">
        <p>At first it was visuals, motion and interfaces.</p>
        <p>Then came APIs, data, systems and architecture.</p>
      </div>
    </div>

  </div>


  <div class="absolute inset-0 pointer-events-none z-0 overflow-hidden mix-blend-multiply opacity-30">
    <div class="absolute top-[-20%] left-[-10%] w-[50vw] h-[50vw] rounded-full bg-warm-gray/20 blur-[100px] hero-paint-1"></div>
    <div class="absolute bottom-[-20%] right-[-10%] w-[60vw] h-[60vw] rounded-full bg-muted-gold/10 blur-[120px] hero-paint-2"></div>
  </div>
</section>

<script>
  import gsap from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const tl = gsap.timeline();

    tl.fromTo('.hero-title',
      { opacity: 0, y: 50, filter: 'blur(10px)' },
      { opacity: 1, y: 0, filter: 'blur(0px)', duration: 2, ease: 'power3.out' }
    )
    .fromTo('.hero-subtitle',
      { opacity: 0, y: 20 },
      { opacity: 1, y: 0, duration: 1.5, ease: 'power2.out' },
      "-=1.2"
    )
    .fromTo('.hero-text p',
      { opacity: 0, y: 10 },
      { opacity: 1, y: 0, duration: 1, stagger: 0.3, ease: 'power2.out' },
      "-=1"
    );

    gsap.to('.hero-paint-1', {
      x: '5%',
      y: '5%',
      scale: 1.1,
      duration: 10,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut'
    });

    gsap.to('.hero-paint-2', {
      x: '-5%',
      y: '-5%',
      scale: 1.15,
      duration: 12,
      repeat: -1,
      yoyo: true,
      ease: 'sine.inOut'
    });
  });
</script>
