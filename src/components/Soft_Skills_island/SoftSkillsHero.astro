---
// SoftSkillsHero.astro
---

<section id="hero" class="ss-hero">
  <!-- Background image -->
  <div class="ss-hero-bg">
    <img
      src="/Soft_Skills /soft_skills_island_background.avif"
      alt="Lighthouse at sunset"
      class="ss-hero-bg-img"
    />
    <div class="ss-hero-bg-overlay"></div>
  </div>

  <!-- Content -->
  <div class="ss-hero-content">
    <!-- Left side -->
    <div class="ss-hero-left ss-fade-up">
      <p class="ss-hero-label">Soft skills</p>
      <h1 class="ss-hero-title">
        Beyond the<br />
        <em>algorithm.</em>
      </h1>

      <p class="ss-hero-sub">
        Beyond the continuous learning, is hidden the motivation, curiosity and habits that drive the journey.
      </p>

      <blockquote class="ss-hero-quote">
        <span class="ss-quote-mark">"</span>
        Usually when a person is successful we see the human who made it, though, far more important are all his losses he went through to achieve it.
        <span class="ss-quote-mark">"</span>
      </blockquote>

      <!-- Scroll cue -->
      <div class="ss-scroll-cue">
        <div class="ss-scroll-line"></div>
        <span>Explore</span>
      </div>
    </div>

    <!-- Right side: atmosphere -->
    <div class="ss-hero-right">
      <div class="ss-hero-atmosphere">
        <div class="ss-atm-tag ss-fade-up" style="animation-delay:0.3s">
          <span>🌊</span> Calm ocean
        </div>
        <div class="ss-atm-tag ss-fade-up" style="animation-delay:0.5s">
          <span>🏔</span> Deep focus
        </div>
        <div class="ss-atm-tag ss-fade-up" style="animation-delay:0.7s">
          <span>📚</span> Continuous learning
        </div>
        <div class="ss-atm-tag ss-fade-up" style="animation-delay:0.9s">
          <span>🔭</span> Wide vision
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .ss-hero {
    position: relative;
    min-height: 100vh;
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .ss-hero-bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .ss-hero-bg-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 30%;
    transform: scale(1.04);
    transition: transform 8s ease;
  }

  .ss-hero:hover .ss-hero-bg-img {
    transform: scale(1.0);
  }

  .ss-hero-bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      105deg,
      rgba(244, 237, 225, 0.82) 0%,
      rgba(244, 237, 225, 0.65) 40%,
      rgba(244, 237, 225, 0.18) 70%,
      rgba(120, 80, 40, 0.08) 100%
    );
  }

  .ss-hero-content {
    position: relative;
    z-index: 10;
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 120px 48px 80px;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  @media (max-width: 768px) {
    .ss-hero-content {
      grid-template-columns: 1fr;
      padding: 100px 24px 64px;
    }
    .ss-hero-right { display: none; }
  }

  .ss-hero-label {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #c5a880;
    margin-bottom: 16px;
  }

  .ss-hero-title {
    font-family: 'Playfair Display', serif;
    font-size: clamp(48px, 7vw, 84px);
    font-weight: 400;
    line-height: 1.08;
    color: #2c1f10;
    margin: 0 0 28px;
  }

  .ss-hero-title em {
    font-style: italic;
    color: #8b6340;
  }

  .ss-hero-sub {
    font-family: 'Inter', sans-serif;
    font-size: 17px;
    font-weight: 300;
    line-height: 1.7;
    color: #5a4030;
    margin-bottom: 36px;
    max-width: 440px;
  }

  .ss-hero-quote {
    margin: 0 0 48px;
    padding: 20px 24px;
    border-left: 2px solid rgba(197, 168, 128, 0.5);
    background: rgba(244, 237, 225, 0.5);
    backdrop-filter: blur(4px);
    border-radius: 0 8px 8px 0;
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 16px;
    line-height: 1.75;
    color: #6b4c2a;
    max-width: 440px;
  }

  .ss-quote-mark {
    font-size: 24px;
    color: #c5a880;
    font-style: normal;
    line-height: 0;
    vertical-align: -8px;
  }

  .ss-scroll-cue {
    display: flex;
    align-items: center;
    gap: 12px;
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #a07850;
  }

  .ss-scroll-line {
    width: 32px;
    height: 1px;
    background: #c5a880;
    animation: ss-pulse-line 2s ease-in-out infinite;
  }

  @keyframes ss-pulse-line {
    0%, 100% { width: 32px; opacity: 0.6; }
    50% { width: 48px; opacity: 1; }
  }

  /* Right atmosphere */
  .ss-hero-right {
    display: flex;
    align-items: flex-end;
    justify-content: flex-end;
  }

  .ss-hero-atmosphere {
    display: flex;
    flex-direction: column;
    gap: 12px;
    align-items: flex-end;
  }

  .ss-atm-tag {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 10px 18px;
    background: rgba(244, 237, 225, 0.55);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(197, 168, 128, 0.3);
    border-radius: 100px;
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: #5a3e22;
    letter-spacing: 0.02em;
  }

  /* Fade up animation */
  .ss-fade-up {
    opacity: 0;
    transform: translateY(24px);
    animation: ss-fadeUp 1s ease forwards;
  }

  @keyframes ss-fadeUp {
    to { opacity: 1; transform: translateY(0); }
  }

  .ss-hero-left { animation-delay: 0.1s; }
</style>
