---
// SoftSkillsArtifacts.astro

const artifacts = [
  {
    type: "Dev Notes",
    emoji: "📓",
    title: "Raw observations",
    desc: "Unfiltered notes from debugging sessions, architecture decisions, and ideas that needed somewhere to land.",
    tag: "Writing",
    color: "#e8d5b0",
  },
  {
    type: "Setup",
    emoji: "⚙️",
    title: "Environment philosophy",
    desc: "How the workspace is configured — terminal, editor, shortcuts. A setup is a mirror of how you think.",
    tag: "Tools",
    color: "#d5e0e8",
  },
  {
    type: "Inspiration",
    emoji: "✦",
    title: "What pulls me in",
    desc: "Books, essays, talks, and people that shaped how I see the craft and what I want to build.",
    tag: "Influences",
    color: "#e8d5c5",
  },
  {
    type: "Sketches",
    emoji: "✏️",
    title: "Before the code",
    desc: "System diagrams, UI wireframes, idea maps. Thinking on paper before it becomes a repository.",
    tag: "Process",
    color: "#d5e8d8",
  },
  {
    type: "Daily Habits",
    emoji: "🌿",
    title: "Routines that compound",
    desc: "The small repeatable actions that build over months: reading, reviewing, resting, creating.",
    tag: "Lifestyle",
    color: "#e8e0d5",
  },
];
---

<section id="artifacts" class="ss-section ss-section-alt ss-section-last">
  <div class="ss-container">
    <div class="ss-section-header ss-reveal">
      <span class="ss-section-num">06</span>
      <h2 class="ss-section-title">Artifacts</h2>
      <p class="ss-section-desc">The residue of a thinking process — things created along the way, not as goals but as byproducts.</p>
    </div>

    <div class="ss-artifacts-scroll">
      <div class="ss-artifacts-track">
        {artifacts.map((a, i) => (
          <div class="ss-artifact-card ss-reveal" style={`animation-delay:${i * 0.1}s`}>
            <div class="ss-artifact-top" style={`background: ${a.color}30`}>
              <span class="ss-artifact-emoji">{a.emoji}</span>
              <span class="ss-artifact-tag">{a.tag}</span>
            </div>
            <div class="ss-artifact-body">
              <p class="ss-artifact-type">{a.type}</p>
              <h3 class="ss-artifact-title">{a.title}</h3>
              <p class="ss-artifact-desc">{a.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>

    <!-- Footer note -->
    <div class="ss-footer-note ss-reveal">
      <div class="ss-footer-line"></div>
      <p class="ss-footer-text">
        "The map is not the territory — but building the map is how you understand the territory."
      </p>
      <div class="ss-footer-sig">Soft Skills Island — a continuous work in progress</div>
    </div>
  </div>
</section>

<style>
  .ss-artifacts-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: thin;
    scrollbar-color: rgba(197, 168, 128, 0.3) transparent;
    padding-bottom: 12px;
    margin-bottom: 64px;
  }

  .ss-artifacts-scroll::-webkit-scrollbar {
    height: 4px;
  }
  .ss-artifacts-scroll::-webkit-scrollbar-track { background: transparent; }
  .ss-artifacts-scroll::-webkit-scrollbar-thumb {
    background: rgba(197, 168, 128, 0.3);
    border-radius: 4px;
  }

  .ss-artifacts-track {
    display: flex;
    gap: 20px;
    width: max-content;
    padding: 4px 2px;
  }

  .ss-artifact-card {
    width: 260px;
    flex-shrink: 0;
    border-radius: 16px;
    overflow: hidden;
    border: 1px solid rgba(197, 168, 128, 0.2);
    background: rgba(255, 252, 245, 0.7);
    transition: all 0.3s ease;
  }

  .ss-artifact-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 16px 40px rgba(120, 80, 30, 0.1);
    border-color: rgba(197, 168, 128, 0.4);
  }

  .ss-artifact-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 20px 20px 16px;
  }

  .ss-artifact-emoji {
    font-size: 28px;
    line-height: 1;
  }

  .ss-artifact-tag {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #8b6340;
    padding: 4px 10px;
    background: rgba(255, 252, 245, 0.7);
    border-radius: 100px;
    border: 1px solid rgba(197, 168, 128, 0.25);
  }

  .ss-artifact-body {
    padding: 12px 20px 24px;
  }

  .ss-artifact-type {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #c5a880;
    margin: 0 0 8px;
  }

  .ss-artifact-title {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 400;
    color: #2c1f10;
    margin: 0 0 10px;
    line-height: 1.3;
  }

  .ss-artifact-desc {
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    font-weight: 300;
    line-height: 1.75;
    color: #7a5830;
    margin: 0;
  }

  /* Footer note */
  .ss-footer-note {
    text-align: center;
    padding: 48px 0 24px;
  }

  .ss-footer-line {
    width: 1px;
    height: 48px;
    background: linear-gradient(to bottom, rgba(197, 168, 128, 0.4), transparent);
    margin: 0 auto 32px;
  }

  .ss-footer-text {
    font-family: 'Playfair Display', serif;
    font-style: italic;
    font-size: 20px;
    color: #7a5830;
    line-height: 1.6;
    max-width: 520px;
    margin: 0 auto 16px;
  }

  .ss-footer-sig {
    font-family: 'Inter', sans-serif;
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(197, 168, 128, 0.6);
  }
</style>
