---
// SoftSkillsJourney.astro

const timeline = [
  {
    year: "Early",
    tag: "Origins",
    title: "Mechanical curiosity",
    text: "Before computers, there were machines. Taking things apart to understand how they worked — not to fix them, but to know them. That instinct never left.",
  },
  {
    year: "2021",
    tag: "Pivot",
    title: "Self-taught developer",
    text: "No bootcamp, no classroom. Books, documentation, late nights, and a lot of broken code. Learned that frustration is part of the process.",
  },
  {
    year: "2022",
    tag: "Deepening",
    title: "Backend & infrastructure",
    text: "Moved deeper into what powers the visible layer — APIs, databases, deployment pipelines. Fell in love with architecture that you never see but always feel.",
  },
  {
    year: "2023",
    tag: "Expanding",
    title: "Cybersecurity interest",
    text: "Realized that understanding systems also means understanding how they break. Security became a natural extension of systems thinking.",
  },
  {
    year: "Now",
    tag: "Ongoing",
    title: "Continuous exploration",
    text: "The map keeps growing. Every solved problem reveals three more questions. That's not a problem — that's the point.",
  },
];
---

<section id="journey" class="ss-section ss-section-alt">
  <div class="ss-container">
    <div class="ss-section-header ss-reveal">
      <span class="ss-section-num">02</span>
      <h2 class="ss-section-title">Journey</h2>
      <p class="ss-section-desc">The path isn't linear, and that's what makes it interesting.</p>
    </div>

    <div class="ss-timeline">
      {timeline.map((item, i) => (
        <div class="ss-timeline-item ss-reveal" style={`animation-delay:${i * 0.12}s`}>
          <div class="ss-timeline-left">
            <span class="ss-timeline-year">{item.year}</span>
            <span class="ss-timeline-tag">{item.tag}</span>
          </div>
          <div class="ss-timeline-spine">
            <div class="ss-timeline-dot"></div>
            {i < timeline.length - 1 && <div class="ss-timeline-line"></div>}
          </div>
          <div class="ss-timeline-right">
            <h3 class="ss-timeline-title">{item.title}</h3>
            <p class="ss-timeline-text">{item.text}</p>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .ss-timeline {
    max-width: 720px;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
  }

  .ss-timeline-item {
    display: grid;
    grid-template-columns: 100px 32px 1fr;
    gap: 0 20px;
  }

  .ss-timeline-left {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    padding-top: 2px;
    gap: 4px;
  }

  .ss-timeline-year {
    font-family: 'Playfair Display', serif;
    font-size: 20px;
    font-weight: 400;
    color: #c5a880;
    line-height: 1;
  }

  .ss-timeline-tag {
    font-family: 'Inter', sans-serif;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #b09070;
  }

  .ss-timeline-spine {
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .ss-timeline-dot {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: #c5a880;
    border: 2px solid rgba(197, 168, 128, 0.3);
    flex-shrink: 0;
    margin-top: 4px;
    box-shadow: 0 0 0 4px rgba(197, 168, 128, 0.08);
  }

  .ss-timeline-line {
    width: 1px;
    flex: 1;
    background: linear-gradient(to bottom, rgba(197, 168, 128, 0.4), rgba(197, 168, 128, 0.1));
    margin-top: 4px;
    margin-bottom: 0;
    min-height: 40px;
  }

  .ss-timeline-right {
    padding-bottom: 44px;
    padding-top: 0;
  }

  .ss-timeline-title {
    font-family: 'Playfair Display', serif;
    font-size: 22px;
    font-weight: 400;
    color: #2c1f10;
    margin: 0 0 10px;
    line-height: 1.3;
  }

  .ss-timeline-text {
    font-family: 'Inter', sans-serif;
    font-size: 15px;
    font-weight: 300;
    line-height: 1.8;
    color: #6b4c2a;
    margin: 0;
    max-width: 460px;
  }

  @media (max-width: 600px) {
    .ss-timeline-item { grid-template-columns: 64px 24px 1fr; gap: 0 12px; }
    .ss-timeline-year { font-size: 16px; }
    .ss-timeline-left { align-items: flex-end; }
  }
</style>
